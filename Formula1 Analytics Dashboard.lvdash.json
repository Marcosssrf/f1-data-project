    {
      "name": "c11473b0",
      "displayName": "Dominant Drivers",
      "queryLines": [
        "WITH drivers_metric AS\n",
        "(\n",
        "    SELECT driver_name,\n",
        "        SUM(race_starts) AS race_starts,\n",
        "        SUM(number_of_wins) AS total_wins,\n",
        "        SUM(number_of_podiums) AS number_of_podiums,\n",
        "        SUM(CASE WHEN standing = 1 THEN 1 ELSE 0 END) AS total_championships\n",
        "        FROM formula1.gold.v_driver_standing\n",
        "        GROUP BY driver_name\n",
        "        HAVING total_championships >= 1\n",
        "        )\n",
        "SELECT driver_name,\n",
        "       race_starts,\n",
        "       total_wins,\n",
        "       number_of_podiums,\n",
        "       total_championships,\n",
        "       (total_championships * 100) + (total_wins * 10) + (number_of_podiums * 3) AS greatness_score\n",
        "    FROM drivers_metric\n",
        "    ORDER BY greatness_score DESC\n",
        "    LIMIT 10"
      ]
    },
    {
      "name": "90914497",
      "displayName": "Dominant Constructors",
      "queryLines": [
        "WITH constructors_metric AS\n",
        "(\n",
        "    SELECT constructor_name,\n",
        "        SUM(race_starts) AS race_starts,\n",
        "        SUM(number_of_wins) AS total_wins,\n",
        "        SUM(number_of_podiums) AS number_of_podiums,\n",
        "        SUM(CASE WHEN standing = 1 THEN 1 ELSE 0 END) AS total_championships\n",
        "        FROM formula1.gold.v_constructors_standing\n",
        "        GROUP BY constructor_name\n",
        "        HAVING total_championships >= 1\n",
        "        )\n",
        "SELECT constructor_name,\n",
        "       race_starts,\n",
        "       total_wins,\n",
        "       number_of_podiums,\n",
        "       total_championships,\n",
        "       (total_championships * 100) + (total_wins * 10) + (number_of_podiums * 3) AS greatness_score\n",
        "    FROM constructors_metric\n",
        "    ORDER BY greatness_score DESC\n",
        "    LIMIT 10"
      ]
    }
  ],
